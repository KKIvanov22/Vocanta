WEAVIATE_API_KEY=YOUR_WEAVIATE_API_KEY
WEAVIATE_URL=http://localhost:8080
# For OpenAI-backed text2vec and Weaviate Agents (set to your OpenAI key or provider key)
WEAVIATE_INFERENCE_API_KEY=
# Optional: gRPC for local/custom Weaviate (default 50051)
WEAVIATE_GRPC_PORT=50051
WEAVIATE_GRPC_SECURE=
# Weaviate Cloud only: Query Agent, Personalization Agent, and optional Transformation Agent
# Set WEAVIATE_CLOUD=true if your cluster URL does not match the default heuristics.
WEAVIATE_CLOUD=
WEAVIATE_DISABLE_AGENTS=false
WEAVIATE_VECTOR_NAME=
WEAVIATE_PERSONALIZATION_STRENGTH=0.85
# Technical preview: modifies objects in place; runs in a background thread after indexing
WEAVIATE_ENABLE_TRANSFORMATION_AGENT=false

# Optional Redis cache
REDIS_URL=redis://127.0.0.1:6379/0

# Flask app
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=false

# Job source runtime controls
JOB_STRICT_COMPLIANCE=true
JOB_SOURCE_TIMEOUT_SECONDS=6
JOB_SEARCH_TOTAL_TIMEOUT_SECONDS=25
JOB_SOURCE_MAX_WORKERS=4
JOB_SOURCE_MAX_ITEMS=30
JOB_SEARCH_MAX_RESULTS=10
JOB_CACHE_TTL_SECONDS=300
JOB_SOURCE_MIN_DOMAIN_INTERVAL=0.3
JOB_SOURCE_ALLOWLIST=linkedin.com,www.linkedin.com,indeed.com,www.indeed.com,dev.bg,www.dev.bg,jobs.bg,www.jobs.bg
JOB_SOURCE_USER_AGENT=VocantaJobAgent/1.0 (+https://github.com/KKIvanov22/Vocanta)

# Compliant feed URLs for sources where direct scraping may be restricted.
LINKEDIN_JOBS_FEED_URL=
INDEED_JOBS_FEED_URL=

# Direct search entry points (used for compliant source fetching).
DEVBG_JOBS_URL=https://dev.bg/jobs/
JOBSBG_SEARCH_URL=https://www.jobs.bg/front_job_search.php